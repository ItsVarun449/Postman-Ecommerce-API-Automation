    {
      "name": "Login API",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "pm.environment.set(\"Token\", jsonData.accessToken);\r",
              "console.log(pm.environment.get(\"Token\"))"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n    \r\n    \"username\": \"emilys\",\r\n    \"password\": \"emilyspass\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{dummy_json}}/auth/login",
          "host": [
            "{{dummy_json}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
